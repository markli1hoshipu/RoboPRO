<?xml version="1.0" ?>
<robot name="dsbcxl">
  <!-- Shared dark gray metallic material definition for drawer -->
  <material name="silver">
    <!-- Medium dark gray -->
    <color rgba="0.3 0.3 0.35 1.0"/>
  </material>
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 -0 0"/>
      <geometry>
        <mesh filename="../blender_public/links/base_link.glb" scale="1 1 1"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 -0 0"/>
      <geometry>
        <!-- Shrink collision mesh by 0.3 to reduce contact between parts -->
        <mesh filename="../blender_public/links/base_link.glb" scale="0.3 0.3 0.3"/>
      </geometry>
    </collision>
  </link>
  <link name="link_1">
