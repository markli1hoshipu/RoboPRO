<?xml version="1.0" ?>
<robot name="hivvdf">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="10.0"/> 
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 -0 0"/>
      <geometry>
        <mesh filename="../blender_public/links/base_link.glb" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 -0 0"/>
      <geometry>
        <mesh filename="../blender_public/links/base_link_collision.glb" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="link_0">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
    <visual>
      <origin xyz="-0.39007673 -0.020861734 0.31230012" rpy="0 -0 0"/>
      <geometry>
        <mesh filename="../blender_public/links/link_0.glb" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="-0.39007673 -0.020861734 0.31230012" rpy="0 -0 0"/>
      <geometry>
        <mesh filename="../blender_public/links/link_0_collision.glb" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="__jointframe__link_0">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-3"/>
    </inertial>
  </link>

  <joint name="j_link_0" type="revolute">
    <parent link="base_link"/>
    <child link="__jointframe__link_0"/>
    <origin xyz="-0.39007673 0.020861734 -0.31230012" rpy="-1.5707963 0 1.5707963"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="3.1241383" effort="20" velocity="1"/> 
    <dynamics damping="1.5" friction="0.5"/> 
  </joint>

  <joint name="link_0__visual_frame_fix" type="fixed">
    <parent link="__jointframe__link_0"/>
    <child link="link_0"/>
    <origin xyz="0 0 0" rpy="1.5707966 1.5707962 3.14159265"/>
  </joint>

  <link name="meta__base_link_fillable_0_0_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
    </inertial>
  </link>

  <link name="__jointframe__meta__base_link_fillable_0_0_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-3"/>
    </inertial>
  </link>

  <joint name="meta__base_link_fillable_0_0_joint" type="fixed">
    <parent link="base_link"/>
    <child link="__jointframe__meta__base_link_fillable_0_0_link"/>
    <origin xyz="0 0 0" rpy="0 -0 0"/>
  </joint>

  <joint name="meta__base_link_fillable_0_0_link__visual_frame_fix" type="fixed">
    <parent link="__jointframe__meta__base_link_fillable_0_0_link"/>
    <child link="meta__base_link_fillable_0_0_link"/>
    <origin xyz="0 0 0" rpy="0 -0 0"/>
  </joint>
</robot>