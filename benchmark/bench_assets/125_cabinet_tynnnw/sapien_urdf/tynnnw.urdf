<?xml version="1.0" ?>
<robot name="tynnnw">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="10.0"/> <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 -0 0"/>
      <geometry>
        <mesh filename="../blender_public/links/base_link.glb" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 -0 0"/>
      <geometry>
        <mesh filename="../blender_public/links/base_link_collision.glb" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="leftdoor">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="-0.23400988 0.0051347096 -0.57802153" rpy="0 -0 0"/>
      <geometry>
        <mesh filename="../blender_public/links/leftdoor.glb" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="-0.23400988 0.0051347096 -0.57802153" rpy="0 -0 0"/>
      <geometry>
        <mesh filename="../blender_public/links/leftdoor_collision.glb" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="__jointframe__leftdoor">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/> 
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
    </inertial>
  </link>

  <joint name="j_leftdoor" type="revolute">
    <parent link="base_link"/>
    <child link="__jointframe__leftdoor"/>
    <origin xyz="0.23400988 -0.0051347096 0.57802153" rpy="-1.5707963 -0 -1.5707963"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0" effort="10" velocity="1"/> <dynamics damping="0.5" friction="0.05"/> 
  </joint>

  <joint name="leftdoor__visual_frame_fix" type="fixed">
    <parent link="__jointframe__leftdoor"/>
    <child link="leftdoor"/>
    <origin xyz="0 0 0" rpy="1.5707963 -1.5707963 0"/>
  </joint>

  <link name="rightdoor">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="-0.23277387 0.0050735669 0.58097678" rpy="0 -0 0"/>
      <geometry>
        <mesh filename="../blender_public/links/rightdoor.glb" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="-0.23277387 0.0050735669 0.58097678" rpy="0 -0 0"/>
      <geometry>
        <mesh filename="../blender_public/links/rightdoor_collision.glb" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="__jointframe__rightdoor">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
    </inertial>
  </link>

  <joint name="j_rightdoor" type="revolute">
    <parent link="base_link"/>
    <child link="__jointframe__rightdoor"/>
    <origin xyz="0.23277387 -0.0050735669 -0.58097678" rpy="-1.5707963 -0 1.5707963"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5707963" effort="10" velocity="1"/> <dynamics damping="0.5" friction="0.05"/>
  </joint>

  <joint name="rightdoor__visual_frame_fix" type="fixed">
    <parent link="__jointframe__rightdoor"/>
    <child link="rightdoor"/>
    <origin xyz="0 0 0" rpy="1.5707963 1.5707963 0"/>
  </joint>

  <link name="meta__base_link_fillable_0_0_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-3"/>
    </inertial>
  </link>

  <link name="__jointframe__meta__base_link_fillable_0_0_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
    </inertial>
  </link>

  <joint name="meta__base_link_fillable_0_0_joint" type="fixed">
    <parent link="base_link"/>
    <child link="__jointframe__meta__base_link_fillable_0_0_link"/>
    <origin xyz="0 0 0" rpy="1.1920929e-07 -0 0"/>
  </joint>

  <joint name="meta__base_link_fillable_0_0_link__visual_frame_fix" type="fixed">
    <parent link="__jointframe__meta__base_link_fillable_0_0_link"/>
    <child link="meta__base_link_fillable_0_0_link"/>
    <origin xyz="0 0 0" rpy="-1.1920929e-07 -0 0"/>
  </joint>
</robot>